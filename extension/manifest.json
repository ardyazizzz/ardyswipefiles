{
  "manifest_version": 3,
  "name": "Swipe.ardy",
  "version": "1.3.0",
  "description": "Extract LinkedIn, Twitter/X, and Pinterest post data and save to your Swipe.ardy collection.",
  "permissions": ["activeTab", "storage", "alarms", "cookies", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.pinterest.com/*",
    "https://dmhiitzunsdqyxopqsby.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://x.com/*", "https://twitter.com/*", "https://*.pinterest.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/x-graphql-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/x-bookmark-watcher.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Swipe.ardy"
  }
}
